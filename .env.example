# Required
DISCORD_TOKEN=your_discord_bot_token

# Recommended for fast slash-command syncing in one server
DISCORD_GUILD_ID=your_discord_server_id

# Defaults for commands
DEFAULT_REGION=NAC
DEFAULT_PLATFORM=pc
TOP_N=25
MAX_ROWS=60

# Live monitor defaults
LIVE_POLL_SECONDS=10
LIVE_MAX_MINUTES=30
LIVE_TOP_TEAMS=25

# Optional. Only used as a fallback if PR is missing from the session page.
TRN_API_KEY=

# Railway sets PORT automatically. Leave this alone locally unless needed.
PORT=8080
