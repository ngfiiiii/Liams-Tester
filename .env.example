# Required
DISCORD_TOKEN=your_discord_bot_token

# Recommended for immediate command syncing in one Discord server
DISCORD_GUILD_ID=your_discord_server_id

# Optional command defaults
DEFAULT_REGION=NAC
DEFAULT_PLATFORM=pc

# Optional PR fallback. The bot can run without this.
TRN_API_KEY=

# Railway creates PORT automatically.
PORT=8080
